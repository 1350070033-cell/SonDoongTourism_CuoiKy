@model IEnumerable<SonDoongTourism.Models.Booking>
@{
    ViewData["Title"] = "Lịch sử đặt tour";
}

<div class="container mt-4">
    <h2 class="mb-4">📋 Lịch sử đặt chỗ của bạn</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">Bạn chưa đặt tour nào. <a href="/Tour">Khám phá ngay!</a></div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover border">
                <thead class="table-light">
                    <tr>
                        <th>Tên Tour</th>
                        <th>Ngày Đặt</th>
                        <th>Thanh Toán</th>
                        <th>Trạng Thái</th>
                        <th>Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.Tour?.Name</strong></td>
                            <td>@item.BookingDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                <span class="text-primary">@item.PaymentMethod</span>
                            </td>
                            <td>
                                <span class="badge @(item.Status == "Đã duyệt" ? "bg-success" : (item.Status == "Đã hủy" ? "bg-danger" : "bg-warning text-dark"))">
                                    @item.Status
                                </span>
                            </td>
                            <td>
                                @if (item.Status == "Chờ duyệt")
                                {
                                    <form asp-action="CancelBooking" asp-controller="Tour" method="post" onsubmit="return confirm('Bạn chắc chắn muốn hủy đơn này?');">
                                        <input type="hidden" name="bookingId" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Hủy đơn</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted small">Không thể hủy</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>