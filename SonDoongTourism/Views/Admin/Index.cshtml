@{
    ViewData["Title"] = "Trang Quản Trị Hệ Thống";
}

<div class="container-fluid mt-4">
    <h2 class="mb-4">📊 Hệ Thống Quản Trị Sơn Đoòng</h2>
    <div class="row">
        <div class="col-md-3">
            <div class="card bg-primary text-white shadow">
                <div class="card-body">
                    <h5>Tổng Tour</h5>
                    <h3>@ViewBag.TotalTours</h3>
                </div>
                <div class="card-footer d-flex align-items-center justify-content-between">
            <a asp-action="ManageTours" asp-controller="Admin" class="small text-white stretched-link text-decoration-none">
                Quản lý danh sách ➔
            </a>
        </div>
            </div>
        </div>
       <div class="col-md-3">
    <div class="card bg-success text-white shadow">
        <div class="card-body">
            Đơn Đặt Tour <br/>
            <h3>@ViewBag.TotalBookings</h3>
        </div>
        <div class="card-footer d-flex align-items-center justify-content-between">
            <a asp-action="ManageBookings" asp-controller="Admin" class="small text-white stretched-link text-decoration-none">
                Xem chi tiết danh sách ➔
            </a>
        </div>
    </div>
    </div>
                    

        <div class="col-md-3">
            <div class="card bg-warning text-dark shadow">
                <div class="card-body">
                    <h5>Khách Hàng</h5>
                    <h3>@ViewBag.TotalUsers</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white shadow">
                <div class="card-body">
                    <h5>Doanh Thu</h5>
                    <h3>@ViewBag.TotalRevenue.ToString("N0") VNĐ</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5 p-4 bg-white border rounded shadow-sm">
        <h4>Đồ thị tăng trưởng đơn hàng</h4>
        <canvas id="myChart" style="width:100%;max-width:800px"></canvas>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const ctx = document.getElementById('myChart');
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: ['Tháng 1', 'Tháng 2', 'Tháng 3', 'Tháng 4'],
            datasets: [{
                label: 'Số đơn hàng',
                data: [12, 19, 3, 5],
                borderColor: 'rgb(75, 192, 192)',
                tension: 0.1
            }]
        }
    });
</script>